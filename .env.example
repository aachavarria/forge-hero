# ── Portrait generation (optional) ────────────────────────────────────────
# Without a key, image UPLOAD still works; only AI generation is disabled.
# Get a key at https://aistudio.google.com/apikey then copy this file to
# .env.local and restart `npm run dev`.
GEMINI_API_KEY=

# Optional: override the image model (default: gemini-2.5-flash-image)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
